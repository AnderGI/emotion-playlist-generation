{
  "name": "emotion-playlist-generation",
  "version": "1.0.0",
  "description": "Generate personalized Spotify playlists based on emotions detected from user images. Utilizes AI models for emotion analysis and integrates with the Spotify API to create mood-driven music experiences.",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest",
    "from:eslintrc:to:eslintconfig:migration": "npx @eslint/migrate-config .eslintrc.json",
    "apps:backoffice:server": "npx tsx ./src/apps/backoffice/Start.ts",
    "lint:src": "npx eslint ./src/",
    "build:prod": "tsc -p tsconfig.prod.json",
    "clean": "npx rimraf ./build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@faker-js/faker": "^9.1.0",
    "@jest/globals": "^29.7.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.7",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@langchain/community": "^0.3.7",
    "@langchain/core": "^0.3.13",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "glob": "^11.0.0",
    "http": "^0.0.1-security",
    "langchain": "^0.3.2",
    "node-dependency-injection": "2.6.11",
    "ts-jest-resolver": "^2.0.1",
    "uuid": "^10.0.0"
  }
}
